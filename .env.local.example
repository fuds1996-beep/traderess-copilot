# Traderess Copilot — Environment Variables
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# On Vercel, add these in Project Settings → Environment Variables.

# ─── Supabase (required) ─────────────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Google Sheets (optional) ────────────────────────────────────────────────
# If set, uses the official Sheets API v4 for faster/more reliable access.
# Get an API key from: https://console.cloud.google.com/apis/credentials
# Enable "Google Sheets API" in your GCP project.
# If not set, falls back to public CSV export (works for link-shared sheets).
GOOGLE_SHEETS_API_KEY=
